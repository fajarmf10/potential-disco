# Stores to monitor (comma-separated store codes)
# Codes: ABDH, AGDP, AJK2, AJK4, ABDG, ASMG, AJOG, ASB1, ASB2,
#        ADPS, ABPN, AMKS, AKNO, APLG, APKU, ABSD, BTR01, BGR01, BKS01, JKT05, JKT06
JIHYO_STORES=ASB1,ASB2,ABDH,AJK2,ABDG,ABSD,BTR01,BGR01

# Timing
JIHYO_CYCLE_MS=30000
JIHYO_RETRY_DEADLINE_MS=18000
JIHYO_RETRY_DELAY_MS=6000

# Redis
JIHYO_REDIS_URL=redis://127.0.0.1:6379

# Telegram (1 bot, 2 chat IDs comma-separated)
# JIHYO_TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# JIHYO_TELEGRAM_CHAT_IDS=-1001234567890,-1009876543210

# Browser
JIHYO_HEADLESS=true
# context | separate
JIHYO_PROFILE_MODE=context
# JIHYO_BROWSER_ARGS=--disable-gpu,--no-zygote
