function UserLocation(e){nearestCity(e.coords.latitude,e.coords.longitude)}function degToRad(e){return e*Math.PI/180}function pythagorasEquirectangular(e,t,a,o){e=degToRad(e),a=degToRad(a),t=degToRad(t);var i=((o=degToRad(o))-t)*Math.cos((e+a)/2),n=a-e;return 6371*Math.sqrt(i*i+n*n)}function nearestCity(e,t){var a,o=99999;for(index=0;index<cities.length;++index){var i=pythagorasEquirectangular(e,t,cities[index].lat,cities[index].long);i<o&&(a=index,o=i)}if(current_storage!=cities[a].code){let e=localStorage.getItem("storage_loc"),t=localStorage.getItem("storage_expiry"),o=(new Date).getTime();if(t&&!isNaN(parseFloat(t))&&isFinite(t)||(t=0),o-t>36e5&&t&&(localStorage.clear(),e=null,t=null),!e||"true"!=e){var n=window.location.origin,r=window.location.pathname;if(r.includes("public")){var c=r.split("public");n=n+(r=c[0]+"public")+"/get-butik-detail"}else n+="/get-butik-detail";$.ajax({type:"POST",url:n,data:{butik_code:cities[a].code,_token:$('meta[name="_token"]').attr("content")},beforeSend:function(){},success:function(e){swal({title:"Belanja di toko terdekat",text:"Kami mencoba mengarahkan Anda agar dapat berbelanja di Toko terdekat yaitu di "+e.name+".",buttons:!0}).then(e=>{if(!0===e)$("#geoloc_storage_id").val(cities[a].code),$("#geoloc-change-location").submit();})}})}}}function initiateGeoLoc(){navigator.geolocation?navigator.geolocation.getCurrentPosition(UserLocation):nearestCity(-6.2058111,106.8383829)}