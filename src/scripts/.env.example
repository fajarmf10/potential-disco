# Logam Mulia credentials
# LM_EMAIL=your_email@example.com
# LM_PASSWORD=your_password

# Store/location codes to check (comma-separated)
# The script checks stock at each location and picks the best one.
# Codes: ABDH, AGDP, AJK2, AJK4, ABDG, ASMG, AJOG, ASB1, ASB2,
#        ADPS, ABPN, AMKS, AKNO, APLG, APKU, ABSD, BTR01, BGR01, BKS01, JKT05, JKT06
LM_STORE_CODES=ASB1,ASB2

# Payment method (transfer_va, transfer_manual, or leave empty to pick in browser)
LM_PAYMENT_METHOD=

# Headless browser mode (true = invisible, false = visible for debugging)
LM_HEADLESS=false

# Browser type for --use-browser mode (chrome or firefox, default: chrome)
# Firefox has a different TLS fingerprint, useful when Chrome is blocked by Cloudflare
# LM_BROWSER=chrome

# Remote debugging port (for --use-browser mode, default: 9222)
# Chrome:  chrome.exe --remote-debugging-port=9222 --user-data-dir="C:\tmp\chrome-profile"
# Firefox: firefox.exe --remote-debugging-port=9222
# LM_DEBUG_PORT=9222

# Number of tabs to race when loading the purchase page (default: 10)
# Higher = faster initial load, but more resource usage
LM_RACE_TABS=10

# Transaction purpose (Investasi or Perdagangan)
LM_TUJUAN_TRANSAKSI=Investasi

# Telegram notifications (stock monitor)
# LM_TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# LM_TELEGRAM_CHAT_ID=-1001234567890
