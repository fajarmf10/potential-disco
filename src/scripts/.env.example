# Logam Mulia credentials
# LM_EMAIL=your_email@example.com
# LM_PASSWORD=your_password
LM_EMAIL=fajarmf78@gmail.com
LM_PASSWORD=P@ssw0rd

# Store/location codes to check (comma-separated)
# The script checks stock at each location and picks the best one.
# Codes: ABDH, AGDP, AJK2, AJK4, ABDG, ASMG, AJOG, ASB1, ASB2,
#        ADPS, ABPN, AMKS, AKNO, APLG, APKU, ABSD, BTR01, BGR01, BKS01, JKT05, JKT06
LM_STORE_CODES=ASB1,ASB2

# Payment method (transfer_va, transfer_manual, or leave empty to pick in browser)
LM_PAYMENT_METHOD=

# Headless browser mode (true = invisible, false = visible for debugging)
LM_HEADLESS=false

# Remote debugging port (for --use-browser mode, default: 9222)
# Launch Chrome with: chrome.exe --remote-debugging-port=9222
# LM_DEBUG_PORT=9222

# Transaction purpose (Investasi or Perdagangan)
LM_TUJUAN_TRANSAKSI=Investasi
